# --- Site URL (recommended for production) ---
# NEXT_PUBLIC_SITE_URL=https://www.expatcopilot.com

# --- Scheduled publishing preview (optional) ---
# Bypass `publishDate` (not `publish: false`) for guides, tools, cities hub, nav, middleware, sitemap.
# `next dev` does this automatically (NODE_ENV=development → see isPubliclyVisible / shouldBypassPublishDateForPreview).
# For production build or `next start` before a publishDate, set:
# Server: CONTENT_PREVIEW=true or Vercel Preview (VERCEL_ENV=preview).
# Client-only checks in the browser: NEXT_PUBLIC_CONTENT_PREVIEW=true when needed.
# CONTENT_PREVIEW=true
# NEXT_PUBLIC_CONTENT_PREVIEW=true
#
# Local “simulate production” (next dev only): open any page with ?preview=true — enforces publishDate like live.
# Clears with ?preview=false. Cookie: expat_simulate_live (not httpOnly; dev-only). Unrelated to CONTENT_PREVIEW above.

# --- Client analytics helpers (PostHog, outbound events) ---
# GA4 gtag.js is embedded in app/layout.tsx. Optional programmatic GA events use lib/analytics/track.ts
# only after analytics cookie consent.

# Optional: allow those programmatic events in development (still requires consent)
# NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Optional: outbound partner referral UTMs appended to external links (when not already set on the URL)
# NEXT_PUBLIC_REFERRAL_UTM_SOURCE=expatcopilot
# NEXT_PUBLIC_REFERRAL_UTM_MEDIUM=referral

# --- Payslip Decoder (defaults: all off; no OCR / image / premium insights in production until rollout) ---
# Server API + pipeline
# ENABLE_PAYSLIP_OCR=false
# ENABLE_PAYSLIP_IMAGE_UPLOAD=false
# ENABLE_PREMIUM_PAYSLIP_INSIGHTS=false
# Client: mirror only if the browser must show extra input modes before calling the API
# NEXT_PUBLIC_ENABLE_PAYSLIP_OCR=false
# NEXT_PUBLIC_ENABLE_PAYSLIP_IMAGE_UPLOAD=false
# NEXT_PUBLIC_ENABLE_PREMIUM_PAYSLIP_INSIGHTS=false
