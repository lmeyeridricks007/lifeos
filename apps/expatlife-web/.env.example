# --- Site URL (recommended for production) ---
# NEXT_PUBLIC_SITE_URL=https://www.expatcopilot.com

# --- Scheduled publishing preview (optional) ---
# Bypass `publishDate` (not `publish: false`) so reviewers see future-dated content.
# Server: CONTENT_PREVIEW=true or Vercel Preview (VERCEL_ENV=preview).
# Client mega menu in preview: also set NEXT_PUBLIC_CONTENT_PREVIEW=true if needed.
# CONTENT_PREVIEW=true
# NEXT_PUBLIC_CONTENT_PREVIEW=true

# --- Google Analytics 4 (Google tag / gtag.js) ---
# Same Measurement ID as Analytics → Admin → Data streams (e.g. the “Install manually” snippet).
# The app injects the equivalent of that script with send_page_view: false; SPA hits use gtag config
# from AnalyticsRouteTracker (lib/analytics/ga.ts).
# Loads only after analytics cookie consent + in production (or NEXT_PUBLIC_ENABLE_ANALYTICS=true).

NEXT_PUBLIC_USE_GTM=false
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-F2H1CJD5ES

# --- Google Tag Manager (optional, instead of direct GA above) ---
# 1. Create a web container at https://tagmanager.google.com → GTM-XXXXXXX.
# 2. In GTM: Google tag / GA4 Configuration → Tag ID = G-F2H1CJD5ES (or your stream ID). Trigger: All Pages.
# 3. SPA: Custom Event trigger `page_view` (dataLayer from lib/analytics/ga.ts).
# Then set NEXT_PUBLIC_USE_GTM=true, NEXT_PUBLIC_GTM_ID=GTM-…, and clear NEXT_PUBLIC_GA_MEASUREMENT_ID.

# Optional: allow analytics scripts in development
# NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Optional: outbound partner referral UTMs appended to external links (when not already set on the URL)
# NEXT_PUBLIC_REFERRAL_UTM_SOURCE=expatcopilot
# NEXT_PUBLIC_REFERRAL_UTM_MEDIUM=referral
