# --- Site URL (recommended for production) ---
# NEXT_PUBLIC_SITE_URL=https://www.expatcopilot.com

# --- Google tag (gtag.js) / GA4 ---
# Same as Google’s “Google tag” snippet (https://www.googletagmanager.com/gtag/js?id=…).
# Loaded only after analytics cookie consent + in production (or set NEXT_PUBLIC_ENABLE_ANALYTICS=true for local tests).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XX169PYS2J

# Leave false to use direct gtag/GA4 above. For a real GTM *container* (GTM-XXXX), set:
# NEXT_PUBLIC_USE_GTM=true
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# …and configure GA4 inside GTM (then omit or ignore GA_MEASUREMENT_ID here).

NEXT_PUBLIC_USE_GTM=false

# Optional: allow analytics scripts in development
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
